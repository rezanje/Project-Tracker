# Reference for required environment variables. Copy values into the right file:
#
#   .env.local  -> VITE_ public vars (read by Vite, reach the browser bundle)
#   .dev.vars   -> server-only secrets (Cloudflare Worker bindings via `wrangler dev`)
#
# Both files are gitignored. Never commit real values.

# --- Public (browser bundle) -> put in .env.local ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets -> put in .dev.vars ---
# SUPABASE_URL / SUPABASE_ANON_KEY here are for server-side clients reading process.env.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
APP_BASE_URL=http://localhost:3000
